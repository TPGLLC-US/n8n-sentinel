{
    "name": "Sentinel Health Check",
    "nodes": [
        {
            "parameters": {
                "rule": {
                    "interval": [
                        {
                            "field": "minutes",
                            "minutes": 1
                        }
                    ]
                }
            },
            "name": "Schedule",
            "type": "n8n-nodes-base.scheduleTrigger",
            "typeVersion": 1.1,
            "position": [
                250,
                300
            ]
        },
        {
            "parameters": {
                "url": "YOUR_WEBHOOK_URL",
                "method": "POST",
                "sendBody": true,
                "bodyParameters": {
                    "parameters": [
                        {
                            "name": "telemetry_type",
                            "value": "heartbeat"
                        },
                        {
                            "name": "timestamp",
                            "value": "={{ new Date().toISOString() }}"
                        },
                        {
                            "name": "instance_metadata",
                            "value": "={{ { n8n_version: $env.N8N_VERSION } }}"
                        }
                    ]
                },
                "authentication": "genericCredentialType",
                "genericAuthType": "httpHeaderAuth",
                "options": {}
            },
            "name": "Send Heartbeat",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.1,
            "position": [
                470,
                300
            ],
            "credentials": {
                "httpHeaderAuth": {
                    "id": "YOUR_SENTINEL_CRED_ID",
                    "name": "Sentinel API Key"
                }
            }
        }
    ],
    "connections": {
        "Schedule": {
            "main": [
                [
                    {
                        "node": "Send Heartbeat",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        }
    }
}