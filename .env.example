# ─── Required: Security ────────────────────────────────────────────────
# Session secret for JWT signing (min 32 chars, must not be 'dev-secret-key')
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=

# Admin credentials (seeded on first startup)
SENTINEL_ADMIN_EMAIL=admin@example.com
SENTINEL_ADMIN_PASSWORD=        # min 12 characters

# ─── Required: Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://sentinel:sentinel@localhost:5432/sentinel

# Postgres password (used by docker-compose for both the DB and connection string)
POSTGRES_PASSWORD=

# ─── Required: Encryption ────────────────────────────────────────────
# Key for encrypting sensitive settings (e.g. API keys stored in DB)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ─── Optional: CORS ───────────────────────────────────────────────────
# In production, set to your dashboard's origin (e.g. https://sentinel.example.com)
# In development, defaults to http://localhost:5173
# CORS_ORIGIN=https://sentinel.example.com

# ─── Optional: Server ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Optional: Public URL ────────────────────────────────────────────
# Public URL for webhook display (used in per-instance ingest URLs)
# If not set, uses the request's protocol://host
# SENTINEL_PUBLIC_URL=https://n8nsentinel.com

# ─── Optional: AI Diagnosis ───────────────────────────────────────────
ANTHROPIC_API_KEY=
